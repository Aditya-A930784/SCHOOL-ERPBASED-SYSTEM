<!DOCTYPE html>
<html lang="mr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>लॉगिन | तुलजाभवानी माध्यमिक विद्यालय</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:linear-gradient(135deg,#0f1f3d 0%,#1a237e 50%,#0f1f3d 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
.login-container{width:100%;max-width:440px;}
.school-header{text-align:center;margin-bottom:32px;color:#fff;}
.school-icon{width:80px;height:80px;background:linear-gradient(135deg,#c9a84c,#e6c668);border-radius:20px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:36px;box-shadow:0 8px 24px rgba(201,168,76,.4);}
.school-name-mar{font-family:'Noto Sans Devanagari',sans-serif;font-size:22px;font-weight:700;color:#fff;line-height:1.3;}
.school-name-eng{font-size:13px;color:#90caf9;font-weight:400;margin-top:4px;}
.school-addr{font-family:'Noto Sans Devanagari',sans-serif;font-size:12px;color:#7986cb;margin-top:4px;}
.login-card{background:#fff;border-radius:20px;padding:36px;box-shadow:0 20px 60px rgba(0,0,0,.3);}
.role-tabs{display:flex;background:#f1f5f9;border-radius:12px;padding:4px;margin-bottom:28px;}
.role-tab{flex:1;padding:10px 16px;border:none;background:transparent;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;color:#64748b;font-family:'DM Sans',sans-serif;}
.role-tab.active{background:#0f1f3d;color:#fff;box-shadow:0 2px 8px rgba(15,31,61,.25);}
.form-label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;}
.input-wrap{position:relative;margin-bottom:18px;}
.input-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:15px;}
.form-input{width:100%;padding:12px 14px 12px 42px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:14px;color:#0f1f3d;background:#f8fafc;transition:all .2s;font-family:'DM Sans',sans-serif;}
.form-input:focus{outline:none;border-color:#1a237e;background:#fff;box-shadow:0 0 0 3px rgba(26,35,126,.08);}
.btn-login{width:100%;padding:14px;background:linear-gradient(135deg,#0f1f3d,#1a237e);color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;letter-spacing:.5px;transition:all .2s;font-family:'DM Sans',sans-serif;}
.btn-login:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(26,35,126,.4);}
.error-msg{background:#fff5f5;border:1px solid #fecaca;color:#c62828;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:18px;display:flex;align-items:center;gap:8px;}
.login-label{font-family:'Noto Sans Devanagari',sans-serif;font-size:13px;color:#475569;text-align:center;margin-top:20px;}
</style>
</head>
<body>
<div class="login-container">
  <div class="school-header">
    <div class="school-icon">🎓</div>
    <div class="school-name-mar">तुलजाभवानी माध्यमिक विद्यालय</div>
    <div class="school-name-eng">Tuljabhavani Madhyamik Vidyalay</div>
    <div class="school-addr">वासुसायगाव, ता. गंगापूर</div>
  </div>

  <div class="login-card">
    <div class="role-tabs">
      <button class="role-tab active" id="tabAdmin" onclick="switchTab('admin')">
        🏫 मुख्याध्यापक
      </button>
      <button class="role-tab" id="tabTeacher" onclick="switchTab('teacher')">
        📚 शिक्षक
      </button>
    </div>

    <% if(typeof error !== 'undefined' && error) { %>
    <div class="error-msg"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <!-- Admin Login -->
    <div id="adminForm">
      <form method="POST" action="/auth/login">
        <input type="hidden" name="role" value="admin"/>
        <div>
          <label class="form-label">Username</label>
          <div class="input-wrap">
            <i class="fas fa-user input-icon"></i>
            <input type="text" name="username" class="form-input" placeholder="mukhyadhyapak" required/>
          </div>
        </div>
        <div>
          <label class="form-label">पासवर्ड</label>
          <div class="input-wrap">
            <i class="fas fa-lock input-icon"></i>
            <input type="password" name="password" class="form-input" placeholder="••••••••" required/>
          </div>
        </div>
        <button type="submit" class="btn-login">🔐 लॉगिन करा — मुख्याध्यापक</button>
      </form>
    </div>

    <!-- Teacher Login -->
    <div id="teacherForm" style="display:none;">
      <form method="POST" action="/auth/login">
        <input type="hidden" name="role" value="teacher"/>
        <div>
          <label class="form-label">Email (ईमेल)</label>
          <div class="input-wrap">
            <i class="fas fa-envelope input-icon"></i>
            <input type="email" name="email" class="form-input" placeholder="teacher@school.com" required/>
          </div>
        </div>
        <div>
          <label class="form-label">पासवर्ड</label>
          <div class="input-wrap">
            <i class="fas fa-lock input-icon"></i>
            <input type="password" name="password" class="form-input" placeholder="••••••••" required/>
          </div>
        </div>
        <button type="submit" class="btn-login">🔐 लॉगिन करा — शिक्षक</button>
      </form>
    </div>

    <div class="login-label">
      तुलजाभवानी माध्यमिक विद्यालय ERP प्रणाली v2.0
    </div>
  </div>
</div>
<script>
function switchTab(role) {
  document.getElementById('adminForm').style.display = role === 'admin' ? '' : 'none';
  document.getElementById('teacherForm').style.display = role === 'teacher' ? '' : 'none';
  document.getElementById('tabAdmin').className = 'role-tab' + (role === 'admin' ? ' active' : '');
  document.getElementById('tabTeacher').className = 'role-tab' + (role === 'teacher' ? ' active' : '');
}
</script>
</body>
</html>
