<%- include('../partials/teacher-layout-head') %>
<% activePage = 'upload'; %>
<div class="app-shell">
<%- include('../partials/teacher-sidebar') %>
<main class="main-content">
  <div class="topbar">
    <div class="topbar-left">
      <button class="hamburger-btn" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
      <div class="page-title">Excel / CSV आयात</div>
    </div>
    <div class="topbar-right">
      <a href="/teacher/students" class="topbar-btn btn-outline"><i class="fas fa-arrow-left"></i> विद्यार्थी यादी</a>
    </div>
  </div>

  <div class="page-content">

    <%# ── Success banner ─────────────────────────────────────── %>
    <% if (success) { %>
    <div class="alert-box alert-success" style="margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
      <span><i class="fas fa-check-circle"></i>&nbsp; <%= success %></span>
      <% if (typeof imported !== 'undefined' && imported > 0) { %>
        <a href="/teacher/students" class="topbar-btn btn-gold" style="padding:8px 18px;font-size:13px;">
          <i class="fas fa-users"></i>&nbsp; विद्यार्थी पाहा →
        </a>
      <% } %>
    </div>

    <%# Row errors (skipped rows) %>
    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="card" style="margin-bottom:16px;border-left:4px solid #ef4444;">
      <div class="card-header" style="background:#fef2f2;padding:12px 16px;">
        <div class="card-title" style="color:#b91c1c;font-size:14px;"><i class="fas fa-times-circle" style="color:#ef4444;"></i>&nbsp; <%= errors.length %> ओळी वगळल्या (Skipped Rows)</div>
      </div>
      <div class="card-body" style="max-height:180px;overflow-y:auto;padding:8px 16px;">
        <% errors.forEach(e => { %>
        <div style="font-size:12px;color:#7f1d1d;padding:3px 0;border-bottom:1px solid #fee2e2;font-family:'Noto Sans Devanagari',sans-serif;">
          <i class="fas fa-chevron-right" style="font-size:10px;margin-right:4px;color:#ef4444;"></i><%= e %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <%# Warnings (imported but fields missing) %>
    <% if (typeof warnings !== 'undefined' && warnings.length > 0) { %>
    <div class="card" style="margin-bottom:16px;border-left:4px solid #f59e0b;">
      <div class="card-header" style="background:#fffbeb;padding:12px 16px;">
        <div class="card-title" style="color:#92400e;font-size:14px;"><i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>&nbsp; <%= warnings.length %> विद्यार्थी आयात झाले — काही माहिती रिकामी</div>
      </div>
      <div class="card-body" style="max-height:180px;overflow-y:auto;padding:8px 16px;">
        <div style="font-size:11px;color:#78350f;margin-bottom:6px;">हे विद्यार्थी यशस्वीरित्या जोडले गेले आहेत, पण खाली दर्शवलेली माहिती Bonafide/Utara साठी आवश्यक आहे — Student Detail मध्ये जाऊन भरा.</div>
        <% warnings.forEach(w => { %>
        <div style="font-size:12px;color:#92400e;padding:3px 0;border-bottom:1px solid #fef3c7;font-family:'Noto Sans Devanagari',sans-serif;">
          <i class="fas fa-info-circle" style="font-size:10px;margin-right:4px;color:#f59e0b;"></i><%= w %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
    <% } %>

    <%# Error banner %>
    <% if (error) { %>
    <div class="alert-box alert-error" style="margin-bottom:16px;">
      <i class="fas fa-exclamation-circle"></i>&nbsp; <%= error %>
    </div>
    <% } %>

    <%# ── Main grid ──────────────────────────────────────────── %>
    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:24px;align-items:start;">

      <%# ── LEFT: Upload + Download ─────────────────────────── %>
      <div>

        <%# Step 1: Download Namoona %>
        <div class="card" style="margin-bottom:20px;border-left:4px solid #16a34a;">
          <div class="card-header" style="background:#f0fdf4;">
            <div class="card-title" style="color:#14532d;">
              <span style="background:#16a34a;color:#fff;border-radius:50%;width:24px;height:24px;display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;margin-right:8px;">1</span>
              नमुना Excel डाउनलोड करा
            </div>
          </div>
          <div class="card-body">
            <p style="font-size:13px;color:#374151;margin-bottom:14px;font-family:'Noto Sans Devanagari',sans-serif;line-height:1.6;">
              खाली दिलेल्या बटणावर क्लिक करून <strong>नमुना Excel</strong> डाउनलोड करा. त्यात <strong>33 columns</strong> आहेत — Bonafide आणि Utara या दोन्ही documents साठी सर्व माहिती.
            </p>
            <a href="/teacher/excel-template" class="topbar-btn" style="width:100%;justify-content:center;padding:13px;font-size:14px;background:#16a34a;color:#fff;border-radius:8px;text-decoration:none;display:flex;gap:8px;align-items:center;font-family:'Noto Sans Devanagari',sans-serif;font-weight:700;">
              <i class="fas fa-file-excel" style="font-size:18px;"></i>
              नमुना Excel डाउनलोड करा (.xlsx)
            </a>
            <div style="margin-top:10px;padding:10px 12px;background:#f0fdf4;border-radius:6px;border:1px dashed #86efac;">
              <div style="font-size:11px;color:#166534;font-family:'Noto Sans Devanagari',sans-serif;line-height:1.8;">
                <i class="fas fa-info-circle"></i>&nbsp; <strong>नमुना फाइल मध्ये:</strong><br>
                • <strong>Sheet 1</strong>: विद्यार्थी माहिती भरण्यासाठी (3 नमुना rows भरलेले)<br>
                • <strong>Sheet 2</strong>: Field Guide — प्रत्येक column काय आहे<br>
                • <strong>Row 4</strong>: ★ Both | ◆ Bonafide | ◇ Utara | ○ Optional
              </div>
            </div>
          </div>
        </div>

        <%# Step 2: Fill and upload %>
        <div class="card" style="border-left:4px solid #1a237e;">
          <div class="card-header" style="background:#f0f2ff;">
            <div class="card-title" style="color:#1a237e;">
              <span style="background:#1a237e;color:#fff;border-radius:50%;width:24px;height:24px;display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;margin-right:8px;">2</span>
              माहिती भरून Upload करा
            </div>
          </div>
          <div class="card-body">
            <p style="font-size:13px;color:#374151;margin-bottom:14px;font-family:'Noto Sans Devanagari',sans-serif;line-height:1.6;">
              नमुना फाइल मध्ये विद्यार्थ्यांची माहिती भरा आणि खाली Upload करा. <strong>Column नावे बदलू नका</strong> — तसेच ठेवा.
            </p>

            <form method="POST" action="/teacher/upload-excel" enctype="multipart/form-data" id="uploadForm">
              <div class="upload-zone" id="uploadZone" onclick="document.getElementById('excelInput').click()">
                <div class="upload-icon">📊</div>
                <div style="font-size:16px;font-weight:700;color:#0f1f3d;margin-bottom:4px;font-family:'Noto Sans Devanagari',sans-serif;">Excel / CSV फाइल येथे टाका</div>
                <div style="font-size:13px;color:#64748b;font-family:'Noto Sans Devanagari',sans-serif;">किंवा क्लिक करून निवडा</div>
                <div style="font-size:12px;color:#94a3b8;margin-top:6px;">.xlsx &nbsp;•&nbsp; .xls &nbsp;•&nbsp; .csv</div>
                <div id="fileNameDisplay" style="display:none;margin-top:12px;padding:8px 16px;background:#e8f5e9;border-radius:8px;font-size:13px;font-weight:600;color:#2e7d32;"></div>
              </div>
              <input type="file" id="excelInput" name="excelFile" accept=".xlsx,.xls,.csv" style="display:none;" onchange="onFileSelect(this)"/>
              <button type="submit" class="topbar-btn btn-gold" id="submitBtn"
                style="width:100%;justify-content:center;padding:13px;font-size:14px;margin-top:14px;opacity:0.45;cursor:not-allowed;font-family:'Noto Sans Devanagari',sans-serif;font-weight:700;" disabled>
                <i class="fas fa-upload"></i>&nbsp; सर्व विद्यार्थी आयात करा
              </button>
            </form>

            <div style="margin-top:12px;padding:10px 12px;background:#fffbeb;border-radius:6px;border:1px dashed #fcd34d;font-size:11px;color:#92400e;font-family:'Noto Sans Devanagari',sans-serif;line-height:1.8;">
              <i class="fas fa-exclamation-triangle"></i>&nbsp; <strong>महत्त्वाचे:</strong><br>
              • फक्त <strong>नमुना Excel मधील columns</strong> वापरा — नावे बदलू नका<br>
              • <strong>नाव</strong> आणि <strong>वर्ग</strong> हे दोन columns आवश्यक आहेत<br>
              • Enrollment ID रिकामे ठेवा — आपोआप तयार होईल<br>
              • आधीच नोंदवलेले विद्यार्थी (duplicate) आपोआप वगळले जातील
            </div>
          </div>
        </div>

      </div>

      <%# ── RIGHT: Column reference table ─────────────────────── %>
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="fas fa-table" style="color:#1a237e;"></i>&nbsp; Column संदर्भ (नमुना Excel मध्ये)</div>
        </div>
        <div class="card-body" style="padding:0;">
          <div style="padding:10px 14px;font-size:12px;color:#475569;background:#f8faff;border-bottom:1px solid var(--border);font-family:'Noto Sans Devanagari',sans-serif;">
            <span style="display:inline-block;background:#1B5E20;color:#fff;border-radius:4px;padding:2px 7px;font-size:10px;font-weight:700;margin-right:4px;">★ Both</span> दोन्ही documents &nbsp;|&nbsp;
            <span style="display:inline-block;background:#1565C0;color:#fff;border-radius:4px;padding:2px 7px;font-size:10px;font-weight:700;margin-right:4px;">◆ Bonafide</span> फक्त Bonafide &nbsp;|&nbsp;
            <span style="display:inline-block;background:#6A1B9A;color:#fff;border-radius:4px;padding:2px 7px;font-size:10px;font-weight:700;margin-right:4px;">◇ Utara</span> फक्त Utara
          </div>
          <div style="overflow-y:auto;max-height:520px;">
            <table style="font-size:11.5px;font-family:'Noto Sans Devanagari',sans-serif;width:100%;border-collapse:collapse;">
              <thead style="position:sticky;top:0;z-index:1;">
                <tr>
                  <th style="background:#1a237e;color:#fff;padding:8px 10px;text-align:left;font-size:11px;">Column (नमुना मध्ये)</th>
                  <th style="background:#1a237e;color:#fff;padding:8px 10px;text-align:center;font-size:11px;white-space:nowrap;">आवश्यक?</th>
                  <th style="background:#1a237e;color:#fff;padding:8px 10px;text-align:left;font-size:11px;">Document Field</th>
                </tr>
              </thead>
              <tbody>
                <%
                const cols = [
                  // label, req, docField
                  ['प्रवेश क्रमांक (Enrollment ID)',     'auto',    'Auto-generated if blank'],
                  ['सरल आय. डि. नं (Saral ID)',         'utara',   'Utara: Saral box grid'],
                  ['युडायस नंबर (UDISE No.)',            'utara',   'Utara: UDISE row'],
                  ['आधार नं. (Aadhar No.)',              'both',    'Bonafide: top | Utara: box grid'],
                  ['विद्यार्थ्याचे संपूर्ण नाव',        'req',     '⚠ आवश्यक — दोन्ही docs'],
                  ['वडिलांचे नाव (Father\'s Name)',      'opt',     '—'],
                  ['आईचे नाव (Mother\'s Name)',          'utara',   'Utara: Field 3'],
                  ['लिंग (Gender)',                      'opt',     '—'],
                  ['जन्म दिनांक DD/MM/YYYY',            'both',    'Bonafide body | Utara Field 7'],
                  ['जन्म दिनांक अक्षरी',                'bonafide','⚠ Bonafide साठी आवश्यक'],
                  ['जन्मस्थळ (Birth Place)',             'utara',   'Utara: Field 6'],
                  ['धर्म (Religion)',                    'utara',   'Utara: Field 4'],
                  ['जात (Caste)',                        'both',    '⚠ Bonafide साठी आवश्यक'],
                  ['प्रवर्ग (Category)',                 'opt',     '—'],
                  ['मातृभाषा (Mother Tongue)',           'utara',   'Utara: Field 5'],
                  ['वर्तमान वर्ग (Current Class)',       'req',     '⚠ आवश्यक — दोन्ही docs'],
                  ['तुकडी (Section)',                    'both',    'Class सोबत जोडला जातो'],
                  ['शैक्षणिक वर्ष (Academic Year)',     'bonafide','⚠ Bonafide साठी आवश्यक'],
                  ['प्रवेश दिनांक (Admission Date)',    'utara',   'Utara: Field 11'],
                  ['प्रवेशाच्या वेळेस वर्ग',            'utara',   'Utara: Field 12'],
                  ['पूर्वीची शाळा (Previous School)',   'utara',   'Utara: Field 9'],
                  ['शाळा सोडताना वर्ग',                 'utara',   'Utara: Field 13'],
                  ['शाळा सोडताना दिनांक',               'utara',   'Utara: Field 14'],
                  ['शाळा सोडण्याचे कारण',              'utara',   'Utara: Field 15'],
                  ['शेरा (Remarks)',                     'utara',   'Utara: Field 16'],
                  ['पालकाचा संपर्क (Contact)',          'opt',     '—'],
                  ['पालकाचा ईमेल (Email)',               'opt',     '—'],
                  ['पत्ता (Address)',                    'opt',     '—'],
                  ['सर्वसाधारण वर्तणूक (Conduct)',      'opt',     '—'],
                ];
                const badges = {
                  req:      ['#B71C1C','⚠ आवश्यक'],
                  both:     ['#1B5E20','★ Both'],
                  bonafide: ['#1565C0','◆ Bonafide'],
                  utara:    ['#6A1B9A','◇ Utara'],
                  opt:      ['#9E9E9E','○ Optional'],
                  auto:     ['#0277BD','⚙ Auto'],
                };
                cols.forEach(([lbl, req, doc], i) => {
                  const [bg, label] = badges[req];
                %>
                <tr style="background:<%= i%2===0 ? '#fafafa' : '#ffffff' %>;">
                  <td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;"><%= lbl %></td>
                  <td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;text-align:center;">
                    <span style="background:<%= bg %>;color:#fff;border-radius:4px;padding:2px 6px;font-size:10px;font-weight:700;white-space:nowrap;"><%= label %></span>
                  </td>
                  <td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;color:#475569;font-size:11px;"><%= doc %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>
</div>

<script>
function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }

function onFileSelect(input) {
  if (input.files && input.files[0]) {
    const f = input.files[0];
    const d = document.getElementById('fileNameDisplay');
    d.textContent = '📎 ' + f.name + ' (' + (f.size/1024).toFixed(1) + ' KB)';
    d.style.display = 'block';
    const btn = document.getElementById('submitBtn');
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
  }
}

// Drag & drop
const zone = document.getElementById('uploadZone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
zone.addEventListener('drop', e => {
  e.preventDefault(); zone.classList.remove('dragover');
  const f = e.dataTransfer.files[0];
  if (f) {
    const dt = new DataTransfer(); dt.items.add(f);
    const inp = document.getElementById('excelInput');
    inp.files = dt.files; onFileSelect(inp);
  }
});

// Show spinner on submit
document.getElementById('uploadForm').addEventListener('submit', function() {
  const btn = document.getElementById('submitBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>&nbsp; आयात होत आहे...';
  btn.disabled = true;
});
</script>
</body>
</html>
