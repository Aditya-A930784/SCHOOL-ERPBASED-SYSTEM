<%- include('../partials/teacher-layout-head') %>
<% activePage = 'students'; %>
<div class="app-shell">
<%- include('../partials/teacher-sidebar') %>
<main class="main-content">
  <div class="topbar">
    <div class="topbar-left">
      <button class="hamburger-btn" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
      <div class="page-title"><%= student ? 'विद्यार्थी संपादन' : 'नवीन विद्यार्थी जोडा' %></div>
    </div>
    <div class="topbar-right">
      <a href="<%= student ? '/teacher/students/'+student._id : '/teacher/students' %>" class="topbar-btn btn-outline">
        <i class="fas fa-arrow-left"></i> मागे
      </a>
    </div>
  </div>

  <div class="page-content">
    <% if(error) { %>
    <div class="alert-box alert-error" style="margin-bottom:16px;">
      <i class="fas fa-exclamation-circle"></i> <%=error%>
    </div>
    <% } %>

    <form method="POST" action="/teacher/students/<%= student ? student._id+'/edit' : 'add' %>" enctype="multipart/form-data">
    <% const v  = (f) => student ? (student[f]||'') : ''; %>
    <% const dv = (f) => student && student[f] ? new Date(student[f]).toISOString().split('T')[0] : ''; %>

    <%# ── SECTION HEADER HELPER ──────────────────────── %>
    <%
    const secHeader = (icon, title, color) => `
      <div class="card-header" style="background:${color}10;border-bottom:2px solid ${color}30;">
        <div class="card-title" style="color:${color};">
          <i class="${icon}" style="color:${color};margin-right:6px;"></i>${title}
        </div>
      </div>`;
    %>

    <!-- ── ROW 1: IDs + Personal ──────────────────────── -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

      <!-- Card: ओळख (Identifiers) -->
      <div class="card">
        <div class="card-header" style="background:#e3f2fd20;border-bottom:2px solid #1565C030;">
          <div class="card-title" style="color:#1565C0;"><i class="fas fa-id-card" style="margin-right:6px;color:#1565C0;"></i>🆔 ओळख माहिती (Identifiers)</div>
        </div>
        <div class="card-body" style="display:grid;gap:12px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">प्रवेश क्रमांक <span style="color:#9E9E9E;font-size:11px;">(Auto)</span></label>
              <input type="text" name="enrollmentId" class="input" value="<%= v('enrollmentId') %>" placeholder="रिकामे सोडा — आपोआप तयार होईल"/>
            </div>
            <div class="form-group">
              <label class="form-label">क्रमांक (Roll No.)</label>
              <input type="text" name="rollNo" class="input" value="<%= v('rollNo') %>" placeholder="वर्गातील क्रमांक"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">आधार नं. <span style="color:#1B5E20;font-size:11px;">★ Bonafide + Utara</span></label>
            <input type="text" name="aadharNo" class="input" value="<%= v('aadharNo') %>" placeholder="XXXX XXXX XXXX"/>
          </div>
          <div class="form-group">
            <label class="form-label">सरल आय. डि. नं <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
            <input type="text" name="saralId" class="input" value="<%= v('saralId') %>" placeholder="19-character Saral ID"/>
          </div>
          <div class="form-group">
            <label class="form-label">युडायस नंबर (UDISE) <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
            <input type="text" name="udiseNo" class="input" value="<%= v('udiseNo') %>" placeholder="School UDISE code"/>
          </div>
        </div>
      </div>

      <!-- Card: वैयक्तिक माहिती -->
      <div class="card">
        <div class="card-header" style="background:#fce4ec20;border-bottom:2px solid #c2185b30;">
          <div class="card-title" style="color:#c2185b;"><i class="fas fa-user" style="margin-right:6px;color:#c2185b;"></i>👤 वैयक्तिक माहिती (Personal)</div>
        </div>
        <div class="card-body" style="display:grid;gap:12px;">
          <div class="form-group">
            <label class="form-label">विद्यार्थ्याचे संपूर्ण नाव <span style="color:red">*</span> <span style="color:#1B5E20;font-size:11px;">★ Both</span></label>
            <input type="text" name="name" class="input" value="<%= v('name') %>" required placeholder="विद्यार्थ्याचे संपूर्ण नाव मराठीत"/>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">जन्म दिनांक (अंकात) <span style="color:#1B5E20;font-size:11px;">★ Both</span></label>
              <input type="date" name="dateOfBirth" class="input" value="<%= dv('dateOfBirth') %>"/>
            </div>
            <div class="form-group">
              <label class="form-label">लिंग (Gender)</label>
              <select name="gender" class="select">
                <option value="">निवडा</option>
                <% ['मुलगा','मुलगी','इतर'].forEach(g => { %>
                <option value="<%=g%>" <%=v('gender')===g?'selected':''%>><%=g%></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">जन्म दिनांक (अक्षरी) <span style="color:#1565C0;font-size:11px;">◆ Bonafide</span></label>
            <input type="text" name="dateOfBirthInWords" class="input" value="<%= v('dateOfBirthInWords') %>" placeholder="उदा. पंधरा जून दोन हजार आठ"/>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">जन्मस्थळ <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
              <input type="text" name="birthPlace" class="input" value="<%= v('birthPlace') %>" placeholder="गाव / शहर"/>
            </div>
            <div class="form-group">
              <label class="form-label">राष्ट्रीयत्व</label>
              <input type="text" name="nationality" class="input" value="<%= v('nationality') || 'भारतीय' %>"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">फोटो</label>
            <input type="file" name="photo" class="input" accept="image/*"/>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 2: धर्म/जात/भाषा + कुटुंब ─────────────── -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

      <!-- Card: धर्म / जात / भाषा -->
      <div class="card">
        <div class="card-header" style="background:#f3e5f520;border-bottom:2px solid #6A1B9A30;">
          <div class="card-title" style="color:#6A1B9A;"><i class="fas fa-om" style="margin-right:6px;"></i>🏷️ धर्म / जात / भाषा</div>
        </div>
        <div class="card-body" style="display:grid;gap:12px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">धर्म (Religion) <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
              <input type="text" name="religion" class="input" value="<%= v('religion') %>" placeholder="हिंदू / मुस्लिम / बौद्ध"/>
            </div>
            <div class="form-group">
              <label class="form-label">जात (Caste) <span style="color:#1B5E20;font-size:11px;">★ Both</span></label>
              <input type="text" name="caste" class="input" value="<%= v('caste') %>" placeholder="माळी / मराठा / हटकर"/>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">प्रवर्ग (Category)</label>
              <select name="category" class="select">
                <% ['सर्वसाधारण','OBC','SC','ST','NT','SBC','VJ','EWS'].forEach(c => { %>
                <option value="<%=c%>" <%=v('category')===c?'selected':''%>><%=c%></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">मातृभाषा <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
              <input type="text" name="motherTongue" class="input" value="<%= v('motherTongue') || 'मराठी' %>"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">सर्वसाधारण वर्तणूक (General Conduct)</label>
            <select name="generalConduct" class="select">
              <% ['चांगले','उत्तम','समाधानकारक','सुधारणा आवश्यक'].forEach(c => { %>
              <option value="<%=c%>" <%=(v('generalConduct')||'चांगले')===c?'selected':''%>><%=c%></option>
              <% }) %>
            </select>
          </div>
        </div>
      </div>

      <!-- Card: कुटुंब माहिती -->
      <div class="card">
        <div class="card-header" style="background:#e8f5e920;border-bottom:2px solid #2e7d3230;">
          <div class="card-title" style="color:#2e7d32;"><i class="fas fa-users" style="margin-right:6px;color:#2e7d32;"></i>👨‍👩‍👧 कुटुंब माहिती (Family)</div>
        </div>
        <div class="card-body" style="display:grid;gap:12px;">
          <div class="form-group">
            <label class="form-label">वडिलांचे नाव (Father's Name)</label>
            <input type="text" name="fatherName" class="input" value="<%= v('fatherName') %>" placeholder="वडिलांचे संपूर्ण नाव"/>
          </div>
          <div class="form-group">
            <label class="form-label">आईचे नाव (Mother's Name) <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
            <input type="text" name="motherName" class="input" value="<%= v('motherName') %>" placeholder="आईचे संपूर्ण नाव"/>
          </div>
          <div class="form-group">
            <label class="form-label">पालकाचे नाव (Guardian Name)</label>
            <input type="text" name="guardianName" class="input" value="<%= v('guardianName') %>" placeholder="पालकाचे नाव (असल्यास)"/>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">पालकाचा संपर्क</label>
              <input type="tel" name="parentContact" class="input" value="<%= v('parentContact') %>" placeholder="मोबाईल नंबर"/>
            </div>
            <div class="form-group">
              <label class="form-label">पालकाचा ईमेल</label>
              <input type="email" name="parentEmail" class="input" value="<%= v('parentEmail') %>" placeholder="email@example.com"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">पत्ता (Address)</label>
            <textarea name="address" class="input" rows="2" placeholder="मु. गाव, ता. तालुका, जि. जिल्हा" style="resize:vertical;"><%= v('address') %></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 3: शालेय माहिती + शाळा सोडणे ────────── -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

      <!-- Card: शालेय माहिती -->
      <div class="card">
        <div class="card-header" style="background:#fff8e120;border-bottom:2px solid #F57F1730;">
          <div class="card-title" style="color:#E65100;"><i class="fas fa-school" style="margin-right:6px;color:#E65100;"></i>📚 शालेय माहिती (Academic)</div>
        </div>
        <div class="card-body" style="display:grid;gap:12px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">वर्ग (Class) <span style="color:red">*</span> <span style="color:#1B5E20;font-size:11px;">★ Both</span></label>
              <select name="currentClass" class="input" required>
                <option value="">-- वर्ग निवडा --</option>
                <% [['१ली','1st'],['२री','2nd'],['३री','3rd'],['४थी','4th'],['५वी','5th'],['६वी','6th'],['७वी','7th'],['८वी','8th'],['९वी','9th'],['१०वी','10th']].forEach(([mr,en]) => { %>
                <option value="<%= mr %>" <%= v('currentClass') === mr ? 'selected' : '' %>><%= mr %> (<%= en %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">तुकडी (Section) <span style="color:#1B5E20;font-size:11px;">★ Both</span></label>
              <select name="currentSection" class="input">
                <option value="">-- तुकडी --</option>
                <% ['A','B','C','D'].forEach(sec => { %>
                <option value="<%= sec %>" <%= v('currentSection') === sec ? 'selected' : '' %>><%= sec %> तुकडी</option>
                <% }) %>
              </select>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">शैक्षणिक वर्ष <span style="color:#1565C0;font-size:11px;">◆ Bonafide</span></label>
              <input type="text" name="academicYear" class="input" value="<%= v('academicYear') %>" placeholder="2024-25"/>
            </div>
            <div class="form-group">
              <label class="form-label">प्रवेश दिनांक <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
              <input type="date" name="admissionDate" class="input" value="<%= dv('admissionDate') %>"/>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">प्रवेशाच्या वेळेस वर्ग <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
              <input type="text" name="admissionClass" class="input" value="<%= v('admissionClass') %>" placeholder="उदा. 5"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">पूर्वीची शाळा <span style="color:#6A1B9A;font-size:11px;">◇ Utara</span></label>
            <input type="text" name="previousSchool" class="input" value="<%= v('previousSchool') %>" placeholder="मागील शाळेचे संपूर्ण नाव"/>
          </div>
        </div>
      </div>

      <!-- Card: शाळा सोडणे (TC/Utara) -->
      <div class="card">
        <div class="card-header" style="background:#fce4ec20;border-bottom:2px solid #b71c1c30;">
          <div class="card-title" style="color:#b71c1c;"><i class="fas fa-door-open" style="margin-right:6px;color:#b71c1c;"></i>🚪 शाळा सोडणे / TC (Utara)</div>
        </div>
        <div class="card-body" style="display:grid;gap:12px;">
          <div style="background:#fff5f5;border:1px dashed #fca5a5;border-radius:8px;padding:10px;font-size:12px;color:#b91c1c;font-family:'Noto Sans Devanagari',sans-serif;">
            <i class="fas fa-info-circle"></i> हे fields फक्त TC देताना / उतारा काढताना भरा. सध्या शिकत असलेल्या विद्यार्थ्यांसाठी रिकामे ठेवा.
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">शाळा सोडताना वर्ग <span style="color:#6A1B9A;font-size:11px;">◇ Utara 13</span></label>
              <input type="text" name="leavingClass" class="input" value="<%= v('leavingClass') %>" placeholder="उदा. 10"/>
            </div>
            <div class="form-group">
              <label class="form-label">शाळा सोडताना दिनांक <span style="color:#6A1B9A;font-size:11px;">◇ Utara 14</span></label>
              <input type="date" name="leavingDate" class="input" value="<%= dv('leavingDate') %>"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">शाळा सोडण्याचे कारण <span style="color:#6A1B9A;font-size:11px;">◇ Utara 15</span></label>
            <input type="text" name="reasonForLeaving" class="input" value="<%= v('reasonForLeaving') %>" placeholder="TC घेतले — पुढील शिक्षणासाठी"/>
          </div>
          <div class="form-group">
            <label class="form-label">शेरा (Remarks) <span style="color:#6A1B9A;font-size:11px;">◇ Utara 16</span></label>
            <input type="text" name="remarks" class="input" value="<%= v('remarks') %>" placeholder="उत्तम / चांगले / विशेष शेरा"/>
          </div>
        </div>
      </div>
    </div>

    <!-- ── LEGEND + SAVE ──────────────────────────────── -->
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
      <div style="font-size:11px;color:#666;display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
        <span style="background:#1B5E20;color:#fff;border-radius:4px;padding:2px 7px;font-weight:700;">★ Both</span> दोन्ही documents
        <span style="background:#1565C0;color:#fff;border-radius:4px;padding:2px 7px;font-weight:700;">◆ Bonafide</span> फक्त Bonafide
        <span style="background:#6A1B9A;color:#fff;border-radius:4px;padding:2px 7px;font-weight:700;">◇ Utara</span> फक्त Utara
      </div>
      <div style="display:flex;gap:12px;">
        <a href="<%= student ? '/teacher/students/'+student._id : '/teacher/students' %>" class="topbar-btn btn-outline">रद्द करा</a>
        <button type="submit" class="topbar-btn btn-gold" style="padding:12px 32px;font-size:15px;">
          <i class="fas fa-save"></i>&nbsp; <%= student ? 'अपडेट करा' : 'जतन करा' %>
        </button>
      </div>
    </div>

    </form>
  </div>
</main>
</div>
<script>function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }</script>
</body></html>
